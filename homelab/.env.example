# Timezone (find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Asia/Kolkata

# Home Assistant config path (your existing config)
HA_CONFIG_PATH=/Users/stevenjohn/homeassistant

# Pi-hole web interface password
PIHOLE_PASSWORD=changeme

# Your Mac's LAN IP (run: python scripts/homelab.py ip)
# Used for Pi-hole and local DNS resolution
LAN_IP=192.168.1.100

# Cloudflare Tunnel (for external access)
# Get your token from: https://one.dash.cloudflare.com/ -> Networks -> Tunnels -> Create
# Format: eyJhIjoiNjM...  (the token from "cloudflared service install <TOKEN>")
CLOUDFLARE_TUNNEL_TOKEN=

# Your base domain for tunnel access
# Services will be available at: home.DOMAIN, ha.DOMAIN, pihole.DOMAIN, etc.
TUNNEL_DOMAIN=stevenjohn.co
