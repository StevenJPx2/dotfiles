# Homepage Dashboard Secrets
#
# Copy this file to /etc/homepage-secrets on the NUC:
#   sudo cp homepage-secrets.example /etc/homepage-secrets
#   sudo chmod 600 /etc/homepage-secrets
#
# These environment variables are used by Homepage widgets.
# Get these values from each service after initial setup.

# Home Assistant Long-Lived Access Token
# Get from: HA → Profile → Long-Lived Access Tokens → Create Token
HOMEPAGE_VAR_HA_TOKEN=your_home_assistant_token_here

# Immich API Key
# Get from: Immich → User Settings → API Keys → New API Key
HOMEPAGE_VAR_IMMICH_KEY=your_immich_api_key_here
